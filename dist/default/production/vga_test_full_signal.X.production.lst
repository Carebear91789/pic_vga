   448                           ;Config register CONFIG1 @ 0x8007
   449                           ;	External Oscillator Mode Selection bits
   450                           ;	FEXTOSC = 0xB, user specified literal
   451                           ;	Power-up Default Value for COSC bits
   452                           ;	RSTOSC = 0x6F, user specified literal
   453                           ;	Clock Out Enable bit
   454                           ;	CLKOUTEN = OFF, CLKOUT function is disabled; I/O function on RA4
   455                           ;	VDD Range Analog Calibration Selection bit
   456                           ;	VDDAR = HI, Internal analog systems are calibrated for operation between VDD = 2.3V - 
      +                          5.5V
   457     8007                     	org	32775
   458     8007  3FFF               	dw	16383
   459                           
   460                           ;Config register CONFIG2 @ 0x8008
   461                           ;	Master Clear Enable bit
   462                           ;	MCLRE = EXTMCLR, If LVP = 0, MCLR pin is MCLR; If LVP = 1, RA3 pin function is MCLR
   463                           ;	Power-up Timer Selection bits
   464                           ;	PWRTS = PWRT_OFF, PWRT is disabled
   465                           ;	WDT Operating Mode bits
   466                           ;	WDTE = OFF, WDT disabled; SEN is ignored
   467                           ;	Brown-out Reset Enable bits
   468                           ;	BOREN = ON, Brown-out Reset Enabled, SBOREN bit is ignored
   469                           ;	Brown-out Reset Voltage Selection bit
   470                           ;	BORV = LO, Brown-out Reset Voltage (VBOR) set to 1.9V
