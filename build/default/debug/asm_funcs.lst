  5304                           ; stack_auto defines a symbol /name/_offset which equates to the
  5305                           ; stack offset of the auto object in question
  5306     0000                     
  5307                           ; stack_param defines a symbol /name/_offset which equates to the
  5308                           ; stack offset of the parameter object in question
  5309     0000                     
